; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="HVAC Simulation"
config/description="Physics-accurate HVAC training simulator"
run/main_scene="res://scenes/pt_chart.tscn"
config/features=PackedStringArray("4.8", "Forward Plus")

[autoload]

DeepSeekConfig="res://scripts/autoload/deepseek_config.gd"
AuditLogger="res://scripts/audit_logger.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
