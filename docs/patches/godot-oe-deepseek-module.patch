+/**************************************************************************/
+/*  deepseek_client.cpp  --  DeepSeek V4 Pro API Client                   */
+/**************************************************************************/
+
+#include "deepseek_client.h"
+
+#include "core/io/http_client.h"
+#include "core/io/json.h"
+#include "core/io/stream_peer_tls.h"
+#include "core/object/class_db.h"
+#include "core/os/os.h"
+#include "core/string/print_string.h"
+#include "core/variant/array.h"
+#include "core/variant/dictionary.h"
+
+// ---------------------------------------------------------------------------
+// Glass Box logger — every request and raw response lands in the editor console.
+// ---------------------------------------------------------------------------
+void DeepSeekClient::_log(const String &p_prefix, const String &p_msg) {
+	String line = "[DeepSeekClient] " + p_prefix + ": " + p_msg;
+	print_line(line);
+}
+
+void DeepSeekClient::_transition(State p_new_state) {
+	state = p_new_state;
+}
+
+void DeepSeekClient::_fail(const String &p_error) {
+	last_error = p_error;
+	state = STATE_ERROR;
+	_log("ERROR", p_error);
+}
+
+// ---------------------------------------------------------------------------
+// Property accessors
+// ---------------------------------------------------------------------------
+void DeepSeekClient::set_api_key(const String &p_key) {
+	api_key = p_key;
+}
+
+String DeepSeekClient::get_api_key() const {
+	return api_key;
+}
+
+void DeepSeekClient::set_model(const String &p_model) {
+	model = p_model;
+}
+
+String DeepSeekClient::get_model() const {
+	return model;
+}
+
+void DeepSeekClient::set_endpoint(const String &p_endpoint) {
+	endpoint = p_endpoint;
+}
+
+String DeepSeekClient::get_endpoint() const {
+	return endpoint;
+}
+
+DeepSeekClient::State DeepSeekClient::get_state() const {
+	return state;
+}
+
+String DeepSeekClient::get_response_text() const {
+	return response_text;
+}
+
+String DeepSeekClient::get_last_error() const {
+	return last_error;
+}
+
+// ---------------------------------------------------------------------------
+// Construction / destruction
+// ---------------------------------------------------------------------------
+DeepSeekClient::DeepSeekClient() :
+		state(STATE_IDLE),
+		port(443),
+		use_tls(true) {
+	http = Ref<HTTPClient>(HTTPClient::create());
+	model = "deepseek-chat";
+	endpoint = "https://api.deepseek.com/v1/chat/completions";
+
+	// FR-SV-005: fall back to environment variable if key not explicitly set.
+	if (api_key.is_empty()) {
+		String env_key = OS::get_singleton()->get_environment("DEEPSEEK_API_KEY");
+		if (!env_key.is_empty()) {
+			api_key = env_key;
+			print_line("[DeepSeekClient] API key loaded from DEEPSEEK_API_KEY environment (" + itos(api_key.length()) + " chars)");
+		}
+	}
+}
+
+DeepSeekClient::~DeepSeekClient() {
+	if (state != STATE_IDLE && state != STATE_COMPLETE && state != STATE_ERROR) {
+		http->close();
+	}
+}
+
+// ---------------------------------------------------------------------------
+// Async request entry point
+// ---------------------------------------------------------------------------
+void DeepSeekClient::request_completion(const String &p_prompt) {
+	if (state != STATE_IDLE && state != STATE_COMPLETE && state != STATE_ERROR) {
+		_log("WARN", "Request already in flight — ignoring.");
+		return;
+	}
+
+	if (api_key.is_empty()) {
+		_fail("API key not set. Call set_api_key() first.");
+		return;
+	}
+
+	// Reset response accumulator.
+	response_text.clear();
+
+	// Parse endpoint URL.
+	String url = endpoint;
+	if (url.begins_with("https://")) {
+		url = url.substr(8);
+		use_tls = true;
+		port = 443;
+	} else if (url.begins_with("http://")) {
+		url = url.substr(7);
+		use_tls = false;
+		port = 80;
+	}
+
+	int slash = url.find("/");
+	if (slash != -1) {
+		host = url.substr(0, slash);
+		path = url.substr(slash);
+	} else {
+		host = url;
+		path = "/";
+	}
+
+	// Build JSON request body (Glass Box — logged before sending).
+	Array messages;
+
+	Dictionary sys_msg;
+	sys_msg["role"] = "system";
+	sys_msg["content"] = "You are a helpful AI assistant integrated into the Godot game engine.";
+	messages.push_back(sys_msg);
+
+	Dictionary user_msg;
+	user_msg["role"] = "user";
+	user_msg["content"] = p_prompt;
+	messages.push_back(user_msg);
+
+	Dictionary body_dict;
+	body_dict["model"] = model;
+	body_dict["messages"] = messages;
+	body_dict["temperature"] = 0.7;
+	body_dict["max_tokens"] = 2048;
+	body_dict["stream"] = false;
+
+	request_body = JSON::stringify(body_dict);
+	_log("REQUEST", request_body);
+
+	// Connect with TLS.
+	Ref<TLSOptions> tls;
+	if (use_tls) {
+		tls = TLSOptions::client();
+	}
+
+	Error err = http->connect_to_host(host, port, tls);
+	if (err != OK) {
+		_fail("connect_to_host failed: " + String::num_int64(err));
+		return;
+	}
+
+	_transition(STATE_CONNECTING);
+	_log("INFO", "Connecting to " + host + ":" + String::num_int64(port));
+}
+
+// ---------------------------------------------------------------------------
+// State-machine poll — call every frame until STATE_COMPLETE or STATE_ERROR.
+// ---------------------------------------------------------------------------
+void DeepSeekClient::poll() {
+	switch (state) {
+		case STATE_IDLE:
+		case STATE_COMPLETE:
+		case STATE_ERROR:
+			return;
+
+		case STATE_CONNECTING: {
+			Error err = http->poll();
+			if (err != OK) {
+				_fail("poll() error during connect: " + String::num_int64(err));
+				return;
+			}
+
+			HTTPClient::Status s = http->get_status();
+			switch (s) {
+				case HTTPClient::STATUS_CONNECTED: {
+					_transition(STATE_CONNECTED);
+					_log("INFO", "Connected to " + host);
+					// Fall through to send request immediately.
+				} break;
+				case HTTPClient::STATUS_CONNECTING:
+				case HTTPClient::STATUS_RESOLVING:
+					return; // Keep polling.
+				default:
+					_fail("Unexpected HTTP status during connect: " + String::num_int64(s));
+					return;
+			}
+		}
+		// Fall-through intentional when connection just established.
+		[[fallthrough]];
+
+		case STATE_CONNECTED: {
+			Vector<String> headers;
+			headers.push_back("Content-Type: application/json");
+			headers.push_back("Authorization: Bearer " + api_key);
+			headers.push_back("Content-Length: " + String::num_int64(request_body.utf8().size()));
+
+			CharString body_utf8 = request_body.utf8();
+			Error err = http->request(HTTPClient::METHOD_POST, path, headers,
+					reinterpret_cast<const uint8_t *>(body_utf8.ptr()), body_utf8.size());
+			if (err != OK) {
+				_fail("request() failed: " + String::num_int64(err));
+				return;
+			}
+
+			_transition(STATE_REQUESTING);
+			_log("INFO", "POST " + path + " sent (" + String::num_int64(body_utf8.size()) + " bytes)");
+			return;
+		}
+
+		case STATE_REQUESTING: {
+			Error err = http->poll();
+			if (err != OK) {
+				_fail("poll() error during request: " + String::num_int64(err));
+				return;
+			}
+
+			HTTPClient::Status s = http->get_status();
+			switch (s) {
+				case HTTPClient::STATUS_BODY: {
+					_transition(STATE_READING);
+					_log("INFO", "Response code: " + String::num_int64(http->get_response_code()));
+					// Fall through to read body.
+				} break;
+				case HTTPClient::STATUS_REQUESTING:
+					return; // Keep polling.
+				default:
+					_fail("Unexpected HTTP status during request: " + String::num_int64(s));
+					return;
+			}
+		}
+		[[fallthrough]];
+
+		case STATE_READING: {
+			Error err = http->poll();
+			if (err != OK) {
+				_fail("poll() error during body read: " + String::num_int64(err));
+				return;
+			}
+
+			if (http->get_status() == HTTPClient::STATUS_BODY) {
+				PackedByteArray chunk = http->read_response_body_chunk();
+				if (chunk.size() > 0) {
+					response_text += String::utf8(reinterpret_cast<const char *>(chunk.ptr()), chunk.size());
+				}
+				return;
+			}
+
+			// Body complete.
+			_transition(STATE_COMPLETE);
+			_log("RESPONSE", response_text);
+			_log("INFO", "Request complete.");
+			http->close();
+			break;
+		}
+	}
+}
